# Build output (root-anchored so cmd/offdock/ is NOT excluded)
/offdock
/offdock.exe
web/dist/
!web/dist/index.html

# Go
vendor/
*.test

# Node
web/node_modules/

# Runtime data
/var/offdock/

# Secrets
*.pem
.env
/etc/offdock/

# IDE
.vscode/
.idea/
*.swp

# Offline bundle artifacts — built fresh per target release, never committed
debs/
images/*.tar
*.tar.gz
/VERSION

# Local scratch / scaffolding scripts (build + test helpers, not part of the app)
_*.sh
