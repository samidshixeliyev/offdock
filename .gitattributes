# Shell scripts and the systemd unit must always use LF — CRLF breaks them on Linux.
*.sh        text eol=lf
*.service   text eol=lf
install.sh  text eol=lf

# OpenTelemetry tracers are mounted into Linux containers — keep them LF.
otel/**     text eol=lf
otel/opentelemetry-javaagent.jar binary

# The bundled Java agent is a binary blob.
*.jar       binary
